{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "engines": {
        "node": ">=24.14.0 <25",
        "npm": ">=11.9.0 <12"
    },
    "packageManager": "npm@11.9.0",
    "scripts": {
        "build": "vue-tsc && vite build",
        "dev": "vite",
        "format": "oxfmt resources/",
        "format:check": "oxfmt --check resources/",
        "format:dirty": "git diff --name-only --diff-filter=ACMR \"*.vue\" \"*.ts\" \"*.js\" | grep \"^resources/js/\" | xargs oxfmt",
        "lint": "oxlint resources/js --fix",
        "lint:strict": "oxlint resources/js"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^3.0.3",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "autoprefixer": "^10.4.12",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.0.0",
        "oxfmt": "^0.46.0",
        "oxlint": "^1.61.0",
        "postcss": "^8.4.31",
        "reka-ui": "^2.9.6",
        "tailwindcss": "^4.2.2",
        "typescript": "^5.6.3",
        "vite": "^8.0.0",
        "vue": "^3.4.0",
        "vue-tsc": "^2.0.24"
    },
    "dependencies": {
        "highlight.js": "^11.11.1",
        "tailwind-merge": "^3.5.0"
    }
}
